#################################################################
#    Object Properties
#################################################################

###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasActionType
:hasActionType rdf:type owl:ObjectProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range :ActionType ;
               rdfs:comment "Links a corrective action to its specific typology."@en ;
               rdfs:label "has action type"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasCategory
:hasCategory rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :RiskCategory ;
             rdfs:comment "Associates a risk with its broad category."@en ;
             rdfs:label "has category"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasCorrectiveAction
:hasCorrectiveAction rdf:type owl:ObjectProperty ;
                     owl:inverseOf :isCorrectiveActionOf ;
                     rdf:type owl:FunctionalProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range :CorrectiveAction ;
                     rdfs:comment "Links an incident to the corrective action taken to address it."@en ;
                     rdfs:label "has corrective action"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasDevice
:hasDevice rdf:type owl:ObjectProperty ;
           owl:inverseOf :isDeviceInvolvedIn ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :Incident ;
           rdfs:range :Device ;
           rdfs:comment "Relates an incident to the specific medical device involved."@en ;
           rdfs:label "has device"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasDeviceType
:hasDeviceType rdf:type owl:ObjectProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( :Device
                                           :Incident
                                           :Risk
                                         )
                           ] ;
               rdfs:range :DeviceType ;
               rdfs:comment "Classifies a device, incident, or risk into a specific device functional type."@en ;
               rdfs:label "has device type"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasIncidentType
:hasIncidentType rdf:type owl:ObjectProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range :IncidentType ;
                 rdfs:comment "Classifies an incident into a specific type based on severity."@en ;
                 rdfs:label "has incident type"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isManufacturerOf ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Links a device to its legal manufacturer."@en ;
                 rdfs:label "has manufacturer"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasProbability
:hasProbability rdf:type owl:ObjectProperty ;
                rdfs:domain :Risk ;
                rdfs:range :Probability ;
                rdfs:comment "Indicates the likelihood of a specific risk occurring."@en ;
                rdfs:label "has probability"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRegulatoryFramework
:hasRegulatoryFramework rdf:type owl:ObjectProperty ;
                        rdfs:domain :Device ;
                        rdfs:range :RegulatoryFramework ;
                        rdfs:comment "Links a device to the regulations governing its use."@en ;
                        rdfs:label "has regulatory framework"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasReportedByEntity
:hasReportedByEntity rdf:type owl:ObjectProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range :Manufacturer ;
                     rdfs:comment "Identifies the manufacturer reporting the incident."@en ;
                     rdfs:label "has reported by entity"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRisk
:hasRisk rdf:type owl:ObjectProperty ;
         owl:inverseOf :isRiskOfIncident ;
         rdf:type owl:FunctionalProperty ;
         rdfs:domain :Incident ;
         rdfs:range :Risk ;
         rdfs:comment "Associates an incident with the specific risk it represents."@en ;
         rdfs:label "has risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Indicates the risk classification of a medical device."@en ;
              rdfs:label "has risk class"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRiskType
:hasRiskType rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :RiskType ;
             rdfs:comment "Specifies the specific nature of the danger represented by a risk."@en ;
             rdfs:label "has risk type"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasSeverity
:hasSeverity rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :Severity ;
             rdfs:comment "Indicates the potential severity of a risk."@en ;
             rdfs:label "has severity"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasStatus
:hasStatus rdf:type owl:ObjectProperty ;
           rdfs:domain :CorrectiveAction ;
           rdfs:range :Status ;
           rdfs:comment "Defines the current state of a corrective action."@en ;
           rdfs:label "has status"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isCorrectiveActionOf
:isCorrectiveActionOf rdf:type owl:ObjectProperty ;
                      rdfs:domain :CorrectiveAction ;
                      rdfs:range :Incident ;
                      rdfs:comment "Indicates the incident for which a specific corrective action was implemented."@en ;
                      rdfs:label "is corrective action of"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isDeviceInvolvedIn
:isDeviceInvolvedIn rdf:type owl:ObjectProperty ;
                    rdfs:domain :Device ;
                    rdfs:range :Incident ;
                    rdfs:comment "Links a medical device to an incident in which it was involved."@en ;
                    rdfs:label "is device involved in"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isManufacturerOf
:isManufacturerOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range :Device ;
                  rdfs:comment "Identifies the medical devices produced by a specific manufacturer."@en ;
                  rdfs:label "is manufacturer of"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isRiskOfIncident
:isRiskOfIncident rdf:type owl:ObjectProperty ;
                  rdfs:domain :Risk ;
                  rdfs:range :Incident ;
                  rdfs:comment "Associates a specific risk with the incident that materialized it."@en ;
                  rdfs:label "is risk of incident"@en .


#################################################################
#    Data properties
#################################################################

###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#action_date
:action_date rdf:type owl:DatatypeProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range <http://purl.org/dc/terms/date> ;
             rdfs:comment "The date when the corrective action was initiated."@en ;
             rdfs:label "action date"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#authorization_number
:authorization_number rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Manufacturer ;
                      rdfs:range xsd:string ;
                      rdfs:comment "The official authorization or certification number of the manufacturer."@en ;
                      rdfs:label "authorization number"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#closure_date
:closure_date rdf:type owl:DatatypeProperty ;
              rdfs:domain :CorrectiveAction ;
              rdfs:range <http://purl.org/dc/terms/date> ;
              rdfs:comment "The date when the corrective action was officially closed."@en ;
              rdfs:label "closure date"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#competent_authority
:competent_authority rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The national regulatory body overseeing the manufacturer."@en ;
                     rdfs:label "competent authority"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#contact_email
:contact_email rdf:type owl:DatatypeProperty ;
               rdfs:domain :Manufacturer ;
               rdfs:range xsd:string ;
               rdfs:comment "The contact email address for the manufacturer."@en ;
               rdfs:label "contact email"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#corrective_action_taken
:corrective_action_taken rdf:type owl:DatatypeProperty ;
                         rdfs:domain :Incident ;
                         rdfs:range xsd:boolean ;
                         rdfs:comment "Indicates whether a corrective action has been implemented."@en ;
                         rdfs:label "corrective action taken"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#countries_affected
:countries_affected rdf:type owl:DatatypeProperty ;
                    rdfs:domain :CorrectiveAction ;
                    rdfs:range xsd:string ;
                    rdfs:comment "A list of countries affected by the corrective action."@en ;
                    rdfs:label "countries affected"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#country
:country rdf:type owl:DatatypeProperty ;
         rdfs:domain :Manufacturer ;
         rdfs:range xsd:string ;
         rdfs:comment "The country where the manufacturer is based."@en ;
         rdfs:label "country"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#country_reported
:country_reported rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Incident ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The country where the incident was reported."@en ;
                  rdfs:label "country reported"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#description
:description rdf:type owl:DatatypeProperty ;
             rdfs:domain owl:Thing ;
             rdfs:range <http://purl.org/dc/terms/description> ;
             rdfs:comment "A detailed textual narrative explaining the entity."@en ;
             rdfs:label "description"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#detection_date
:detection_date rdf:type owl:DatatypeProperty ;
                rdfs:domain :Incident ;
                rdfs:range <http://purl.org/dc/terms/date> ;
                rdfs:comment "The date when the incident or risk was first detected."@en ;
                rdfs:label "detection date"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#device_id
:device_id rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Device ;
           rdfs:range <http://purl.org/dc/terms/identifier> ;
           rdfs:comment "The unique identifier assigned to a specific medical device unit or model."@en ;
           rdfs:label "device id"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#device_name
:device_name rdf:type owl:DatatypeProperty ;
             rdfs:domain :Device ;
             rdfs:range xsd:string ;
             rdfs:comment "The commercial or common name of the medical device."@en ;
             rdfs:label "device name"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#devices_affected
:devices_affected rdf:type owl:DatatypeProperty ;
                  rdfs:domain :CorrectiveAction ;
                  rdfs:range xsd:integer ;
                  rdfs:comment "The total number of device units affected by a corrective action."@en ;
                  rdfs:label "devices affected"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#eudamed_fsca_ref
:eudamed_fsca_ref rdf:type owl:DatatypeProperty ;
                  rdfs:domain :CorrectiveAction ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The reference number for the Field Safety Corrective Action in EUDAMED."@en ;
                  rdfs:label "eudamed fsca ref"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#eudamed_incident_ref
:eudamed_incident_ref rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Incident ;
                      rdfs:range xsd:string ;
                      rdfs:comment "The reference number for the incident in EUDAMED."@en ;
                      rdfs:label "eudamed incident ref"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#eudamed_srn
:eudamed_srn rdf:type owl:DatatypeProperty ;
             rdfs:domain :Manufacturer ;
             rdfs:range xsd:string ;
             rdfs:comment "The Single Registration Number for the manufacturer in EUDAMED."@en ;
             rdfs:label "eudamed srn"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#event_date
:event_date rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range <http://purl.org/dc/terms/date> ;
            rdfs:comment "The specific calendar date when the incident occurred."@en ;
            rdfs:label "event date"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#fsca_id
:fsca_id rdf:type owl:DatatypeProperty ;
         rdfs:domain :CorrectiveAction ;
         rdfs:range <http://purl.org/dc/terms/identifier> ;
         rdfs:comment "The identifier for the Field Safety Corrective Action."@en ;
         rdfs:label "fsca id"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#imdrf_code
:imdrf_code rdf:type owl:DatatypeProperty ;
            rdfs:domain :Risk ;
            rdfs:range <http://purl.org/dc/terms/identifier> ;
            rdfs:comment "The International Medical Device Regulators Forum code associated with the risk."@en ;
            rdfs:label "imdrf code"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#incident_id
:incident_id rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Incident ;
             rdfs:range <http://purl.org/dc/terms/identifier> ;
             rdfs:comment "The unique identifier for the reported incident."@en ;
             rdfs:label "incident id"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#intended_purpose
:intended_purpose rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Device ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The medical purpose for which the device is intended."@en ;
                  rdfs:label "intended purpose"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#is_active
:is_active rdf:type owl:DatatypeProperty ;
           rdfs:domain :Device ;
           rdfs:range xsd:boolean ;
           rdfs:comment "Boolean flag indicating if the device is active."@en ;
           rdfs:label "is active"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#is_implantable
:is_implantable rdf:type owl:DatatypeProperty ;
                rdfs:domain :Device ;
                rdfs:range xsd:boolean ;
                rdfs:comment "Boolean flag indicating whether the device is designed to be implanted."@en ;
                rdfs:label "is implantable"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#is_ivd
:is_ivd rdf:type owl:DatatypeProperty ;
        rdfs:domain :Device ;
        rdfs:range xsd:boolean ;
        rdfs:comment "Boolean flag indicating if the device is an in vitro diagnostic device."@en ;
        rdfs:label "is ivd"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#is_reusable
:is_reusable rdf:type owl:DatatypeProperty ;
             rdfs:domain :Device ;
             rdfs:range xsd:boolean ;
             rdfs:comment "Boolean flag indicating if the device is intended for reuse."@en ;
             rdfs:label "is reusable"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#manufacturer_id
:manufacturer_id rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Manufacturer ;
                 rdfs:range <http://purl.org/dc/terms/identifier> ;
                 rdfs:comment "The unique identifier for the manufacturer."@en ;
                 rdfs:label "manufacturer id"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#name
:name rdf:type owl:DatatypeProperty ;
      rdfs:domain :Manufacturer ;
      rdfs:range xsd:string ;
      rdfs:comment "The name of the manufacturer."@en ;
      rdfs:label "name"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#outcome
:outcome rdf:type owl:DatatypeProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "The result or consequence of the incident for the patient."@en ;
         rdfs:label "outcome"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#patient_age
:patient_age rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:integer ;
             rdfs:comment "The age of the patient involved in the incident."@en ;
             rdfs:label "patient age"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#patient_sex
:patient_sex rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:string ;
             rdfs:comment "The sex of the patient involved in the incident."@en ;
             rdfs:label "patient sex"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#report_date
:report_date rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range <http://purl.org/dc/terms/date> ;
             rdfs:comment "The date when the incident was officially reported."@en ;
             rdfs:label "report date"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#risk_id
:risk_id rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Risk ;
         rdfs:range <http://purl.org/dc/terms/identifier> ;
         rdfs:comment "The unique identifier for the risk."@en ;
         rdfs:label "risk id"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#risk_name
:risk_name rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "The descriptive name of the risk."@en ;
           rdfs:label "risk name"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#scope
:scope rdf:type owl:DatatypeProperty ;
       rdfs:domain :CorrectiveAction ;
       rdfs:range xsd:string ;
       rdfs:comment "The scope or affected range of a corrective action."@en ;
       rdfs:label "scope"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#udi_di
:udi_di rdf:type owl:DatatypeProperty ;
        rdfs:domain :Device ;
        rdfs:range <http://purl.org/dc/terms/identifier> ;
        rdfs:comment "The Unique Device Identification Device Identifier."@en ;
        rdfs:label "udi di"@en .


#################################################################
#    Classes
#################################################################

###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ActionType
:ActionType rdf:type owl:Class ;
            rdfs:comment "The specific category of a Field Safety Corrective Action."@en ;
            rdfs:label "Action Type"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :DeviceType ;
              rdfs:comment "A device dependent on a source of energy other than the human body."@en ;
              rdfs:label "Active Device"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :DeviceType ;
               rdfs:comment "An active medical device intended to be partially or totally implanted."@en ;
               rdfs:label "Active Implant"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ActiveImplantableDevice
:ActiveImplantableDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device ;
                         rdfs:comment "Devices that are both active and implantable, inferred by rules."@en ;
                         rdfs:label "Active Implantable Device"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassC
:ClassC rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassD
:ClassD rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Closed
:Closed rdf:type owl:Class ;
        rdfs:subClassOf :Status ;
        owl:disjointWith :Open .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#CompletedAction
:CompletedAction rdf:type owl:Class ;
                 rdfs:subClassOf :CorrectiveAction ;
                 rdfs:comment "Corrective actions that have an official closure date."@en ;
                 rdfs:label "Completed Action"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :RiskType ;
                   rdfs:comment "Risk of contamination leading to systematic diagnostic errors."@en ;
                   rdfs:label "Contamination Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :action_date ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:date
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :countries_affected ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :description ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :devices_affected ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:integer
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :eudamed_fsca_ref ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :fsca_id ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :scope ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :closure_date ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:date
                                  ] ;
                  rdfs:comment "Action taken to eliminate the cause of a detected nonconformity or incident."@en ;
                  rdfs:label "Corrective Action"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Critical
:Critical rdf:type owl:Class ;
          rdfs:subClassOf :Severity .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#CriticalManufacturer
:CriticalManufacturer rdf:type owl:Class ;
                      rdfs:subClassOf :Manufacturer ;
                      rdfs:comment "Manufacturer involved in incidents with critical severity."@en ;
                      rdfs:label "Critical Manufacturer"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :RiskType ;
                   rdfs:comment "Risk related to exploitable software vulnerabilities enabling unauthorized access."@en ;
                   rdfs:label "Cybersecurity Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :device_id ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :device_name ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :intended_purpose ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_active ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_implantable ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_ivd ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_reusable ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :udi_di ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ;
        rdfs:comment "A medical instrument, apparatus, or machine used for healthcare purposes."@en ;
        rdfs:label "Device"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DeviceFailure
:DeviceFailure rdf:type owl:Class ;
               rdfs:subClassOf :RiskCategory .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DevicePerformance
:DevicePerformance rdf:type owl:Class ;
                   rdfs:subClassOf :RiskCategory .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DeviceSafety
:DeviceSafety rdf:type owl:Class ;
              rdfs:subClassOf :RiskCategory .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:comment "Functional classification of the medical device."@en ;
            rdfs:label "Device Type"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DiagnosticError
:DiagnosticError rdf:type owl:Class ;
                 rdfs:subClassOf :RiskCategory .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :RiskType ;
                rdfs:comment "Specific risk type representing potential diagnostic errors."@en ;
                rdfs:label "Diagnostic Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#High
:High rdf:type owl:Class ;
      rdfs:subClassOf :Probability .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#HighRiskIncident
:HighRiskIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  rdfs:comment "Incidents associated with critical risks, inferred by rules."@en ;
                  rdfs:label "High Risk Incident"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#IVDR
:IVDR rdf:type owl:Class ;
      rdfs:subClassOf :RegulatoryFramework ;
      owl:disjointWith :MDR .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         rdfs:subClassOf :DeviceType ;
                         rdfs:comment "Implantable device that requires an active energy source."@en ;
                         rdfs:label "Implantable Active Device"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :DeviceType ;
                   rdfs:comment "A device intended to be introduced into the human body."@en ;
                   rdfs:label "Implantable Device"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :ActionType ;
                  rdfs:comment "Corrective action performed directly on the device in the field."@en ;
                  rdfs:label "In Situ Correction" .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :DeviceType ;
                         rdfs:comment "A device used in vitro for the examination of specimens."@en ;
                         rdfs:label "In Vitro Diagnostic Device"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :corrective_action_taken ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:boolean
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :country_reported ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :description ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :detection_date ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :eudamed_incident_ref ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :event_date ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :incident_id ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :outcome ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :report_date ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :patient_age ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:integer
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :patient_sex ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ;
          rdfs:comment "An adverse event or malfunction associated with a medical device."@en ;
          rdfs:label "Incident"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#IncidentType
:IncidentType rdf:type owl:Class ;
              rdfs:comment "Classification of the nature and severity of an adverse event."@en ;
              rdfs:label "Incident Type"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :RiskType ;
               rdfs:comment "Risk of device-related infection or biofilm formation."@en ;
               rdfs:label "Infection Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :RiskType ;
            rdfs:comment "Risk of physical harm to the patient."@en ;
            rdfs:label "Injury Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :RiskType ;
                  rdfs:comment "Risk of unintended interference."@en ;
                  rdfs:label "Interference Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Low
:Low rdf:type owl:Class ;
     rdfs:subClassOf :Probability .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#MDR
:MDR rdf:type owl:Class ;
     rdfs:subClassOf :RegulatoryFramework .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :RiskType ;
                 rdfs:comment "Risk type indicating structural or functional failure."@en ;
                 rdfs:label "Malfunction Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :authorization_number ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :competent_authority ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :contact_email ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :country ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :eudamed_srn ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :manufacturer_id ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :name ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ;
              rdfs:comment "The legal entity responsible for the design and compliance of the medical device."@en ;
              rdfs:label "Manufacturer"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :RiskType ;
              rdfs:comment "Risk associated with the physical materials of the device."@en ;
              rdfs:label "Material Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Medium
:Medium rdf:type owl:Class ;
        rdfs:subClassOf :Probability .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Moderate
:Moderate rdf:type owl:Class ;
          rdfs:subClassOf :Severity .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :IncidentType ;
                  owl:disjointWith :SeriousIncident ;
                  rdfs:comment "An incident that did not result in harm but had the potential to do so."@en ;
                  rdfs:label "Near Miss Incident"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Open
:Open rdf:type owl:Class ;
      rdfs:subClassOf :Status .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#PatientHarm
:PatientHarm rdf:type owl:Class ;
             rdfs:subClassOf :RiskCategory .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Probability
:Probability rdf:type owl:Class ;
             rdfs:comment "The likelihood of a specific risk or hazard occurring."@en ;
             rdfs:label "Probability"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ProductQuality
:ProductQuality rdf:type owl:Class ;
                rdfs:subClassOf :RiskCategory .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :RiskType ;
               rdfs:comment "Risk associated with unintended ionizing radiation exposure."@en ;
               rdfs:label "Radiation Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :ActionType ;
        rdfs:comment "Action to return a device to the manufacturer."@en ;
        rdfs:label "Recall" .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     rdfs:comment "The set of laws and regulations governing medical device safety."@en ;
                     rdfs:label "Regulatory Framework"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :description ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :imdrf_code ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :risk_id ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :risk_name ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ;
      rdfs:comment "A potential source of harm or adverse health effect associated with a device."@en ;
      rdfs:label "Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#RiskCategory
:RiskCategory rdf:type owl:Class ;
              rdfs:comment "A broad grouping of risks based on their origin or impact."@en ;
              rdfs:label "Risk Category"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "Classification of a device based on its risk to patients and users."@en ;
           rdfs:label "Risk Class"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#RiskType
:RiskType rdf:type owl:Class ;
          rdfs:comment "The specific nature of the danger represented by a risk."@en ;
          rdfs:label "Risk Type"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :ActionType ;
             rdfs:comment "Safety communication issued to users regarding a medical device."@en ;
             rdfs:label "Safety Alert" .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :DeviceType ;
                rdfs:comment "An IVD device intended to be used by a lay person."@en ;
                rdfs:label "Self Test Device"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Serious
:Serious rdf:type owl:Class ;
         rdfs:subClassOf :Severity .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :IncidentType ;
                 rdfs:comment "An incident that directly or indirectly led to death or serious injury."@en ;
                 rdfs:label "Serious Incident"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Severity
:Severity rdf:type owl:Class ;
          rdfs:comment "The measure of the possible consequences of a hazard."@en ;
          rdfs:label "Severity"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :DeviceType ;
                 rdfs:comment "A device intended to be used on one individual during a single procedure."@en ;
                 rdfs:label "Single Use Device"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :RiskType ;
              rdfs:comment "Risk associated with software bugs or malfunctions."@en ;
              rdfs:label "Software Risk"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Status
:Status rdf:type owl:Class ;
        rdfs:comment "The current state of a corrective action or investigation process."@en ;
        rdfs:label "Status"@en .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :ActionType ;
            rdfs:comment "Urgent safety notice regarding the proper use of a device."@en ;
            rdfs:label "User Notice" .


