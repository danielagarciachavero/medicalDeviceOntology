###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ,
                   :SafetyAlert ;
          :hasStatus :Open ;
          :action_date "2024-02-01"^^xsd:date ;
          :countries_affected "EU-wide" ;
          :description "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          :devices_affected 850 ;
          :eudamed_fsca_ref "EU-FSCA-2024-000001" ;
          :fsca_id "FSCA-001" ;
          :scope "All HeartMate 3 LVAD units implanted since 2020" .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#FSCA-002
:FSCA-002 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ,
                   :Recall ;
          :hasStatus :Closed ;
          :action_date "2024-02-28"^^xsd:date ;
          :closure_date "2024-05-31"^^xsd:date ;
          :countries_affected "EU-wide + UK" ;
          :description "Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced." ;
          :devices_affected 1240 ;
          :eudamed_fsca_ref "EU-FSCA-2024-000002" ;
          :fsca_id "FSCA-002" ;
          :scope "Micra AV lots manufactured between 2022-09 and 2023-03" .


###  https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#FSCA-003
:FSCA-003 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ,
                   :InSituCorrection ;
          :hasStatus :Closed ;
          :action_date "2024-03-15"^^xsd:date ;
          :closure_date "2024-06-30"^^xsd:date ;
          :countries_affected "EU-wide" ;
          :description "Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres." ;
          :devices_affected 320 ;
          :eudamed_fsca_ref "EU-FSCA-2024-000003" ;
          :fsca_id "FSCA-003" ;
          :scope "Portico THV sizes 23mm and 25mm from lots before 2023-11" .


