@prefix : <https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#> .

<https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl> rdf:type owl:Ontology ;
                                                                              owl:versionIRI <https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto-1.0.0.owl> ;
                                                                              <http://purl.org/dc/elements/1.1/contributor> "UOC - Universitat Oberta de Catalunya"@en ;
                                                                              <http://purl.org/dc/elements/1.1/creator> "Daniela Garcia Chavero"@en ,
                                                                                                                        "Johan Marin Chamorro"@en ;
                                                                              <http://purl.org/dc/elements/1.1/description> "The medical device ontology is designed to structure and represent information about medical devices and post-market surveillance within the European regulatory framework (MDR/IVDR)."@en ;
                                                                              <http://purl.org/dc/elements/1.1/title> "Medical Device Regulatory and Surveillance Ontology"@en ;
                                                                              <http://purl.org/dc/terms/abstract> "Ontology detailing medical devices, post-market surveillance, incidents, and field safety corrective actions compliant with EU MDR/IVDR regulations."@en ;
                                                                              <http://purl.org/dc/terms/bibliographicCitation> "Garcia Chavero, D. and Marin Chamorro, J. Medical Device Regulatory and Surveillance Ontology. 2026."@en ;
                                                                              <http://purl.org/dc/terms/created> "2026-04-23"@en ;
                                                                              <http://purl.org/dc/terms/issued> "2026-04-23"@en ;
                                                                              <http://purl.org/dc/terms/license> <http://creativecommons.org/licenses/by/4.0/> ;
                                                                              <http://purl.org/dc/terms/modified> "2026-04-23"@en ;
                                                                              <http://purl.org/dc/terms/publisher> "FUOC - Fundació Universitat Oberta de Catalunya"@en ;
                                                                              <http://purl.org/dc/terms/source> <https://eur-lex.europa.eu/eli/reg/2017/745/oj> ;
                                                                              <http://purl.org/ontology/bibo/doi> "10.5281/zenodo.1000000"@en ;
                                                                              <http://purl.org/ontology/bibo/status> "Published"@en ;
                                                                              <http://purl.org/vocab/vann/preferredNamespacePrefix> "mdo"@en ;
                                                                              <http://purl.org/vocab/vann/preferredNamespaceUri> : ;
                                                                              owl:versionInfo "Final Version - PEC2"@en ;
                                                                              <https://schema.org/citation> "Garcia Chavero, D. and Marin Chamorro, J. Medical Device Regulatory and Surveillance Ontology."@en ;
                                                                              <https://schema.org/includedInDataCatalog> <https://lov.linkeddata.es/dataset/lov> ;
                                                                              <https://schema.org/logo> <https://upload.wikimedia.org/wikipedia/commons/thumb/8/8a/Small_logo_UOC.svg/3840px-Small_logo_UOC.svg.png> ;
                                                                              <https://w3id.org/mod#createdWith> <https://chowlk.linkeddata.es/> .

