#################################################################
#    Annotations
#################################################################

:ClassC rdfs:comment "Moderate to high individual risk and low to moderate public health risk (IVDR)."@en ;
        rdfs:label "Class C"@en .


:ClassD rdfs:comment "High individual risk and high public health risk (IVDR)."@en ;
        rdfs:label "Class D"@en .


:ClassIII rdfs:comment "Highest risk class for medical devices."@en ;
          rdfs:label "Class III"@en .


:ClassIIa rdfs:comment "Low to moderate risk class for medical devices."@en ;
          rdfs:label "Class IIa"@en .


:ClassIIb rdfs:comment "Moderate to high risk class for medical devices."@en ;
          rdfs:label "Class IIb"@en .


:Closed rdfs:comment "Status indicating that the action has been completed."@en ;
        rdfs:label "Closed"@en .


:Critical rdfs:comment "Highest level of severity representing extreme danger to life."@en ;
          rdfs:label "Critical"@en .


:DeviceFailure rdfs:comment "Risk category involving the breakdown or failure of the device."@en ;
               rdfs:label "Device Failure"@en .


:DevicePerformance rdfs:comment "Risk category involving inadequate performance of the device."@en ;
                   rdfs:label "Device Performance"@en .


:DeviceSafety rdfs:comment "Risk category involving compromised safety of the device."@en ;
              rdfs:label "Device Safety"@en .


:DiagnosticError rdfs:comment "Risk category involving incorrect diagnostic results."@en ;
                 rdfs:label "Diagnostic Error"@en .


:High rdfs:comment "High likelihood of occurrence."@en ;
      rdfs:label "High"@en .


:IVDR rdfs:comment "In Vitro Diagnostic Regulation (EU) 2017/746."@en ;
      rdfs:label "IVDR"@en .


:Low rdfs:comment "Low likelihood of occurrence."@en ;
     rdfs:label "Low"@en .


:MDR rdfs:comment "Medical Device Regulation (EU) 2017/745."@en ;
     rdfs:label "MDR"@en .


:Medium rdfs:comment "Medium likelihood of occurrence."@en ;
        rdfs:label "Medium"@en .


:Moderate rdfs:comment "Moderate level of severity."@en ;
          rdfs:label "Moderate"@en .


:Open rdfs:comment "Status indicating that the action is still in progress."@en ;
      rdfs:label "Open"@en .


:PatientHarm rdfs:comment "Risk category involving direct injury to the patient."@en ;
             rdfs:label "Patient Harm"@en .


:ProductQuality rdfs:comment "Risk category related to manufacturing or product defects."@en ;
                rdfs:label "Product Quality"@en .


:Serious rdfs:comment "High level of severity involving significant injury or impairment."@en ;
         rdfs:label "Serious"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ActiveDevice
                :ActiveImplant
                :ImplantableActiveDevice
                :ImplantableDevice
                :InVitroDiagnosticDevice
                :SelfTestDevice
                :SingleUseDevice
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ClassC
                :ClassD
                :ClassIII
                :ClassIIa
                :ClassIIb
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ContaminationRisk
                :CybersecurityRisk
                :DiagnosticRisk
                :InfectionRisk
                :InjuryRisk
                :InterferenceRisk
                :MalfunctionRisk
                :MaterialRisk
                :RadiationRisk
                :SoftwareRisk
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Critical
                :Moderate
                :Serious
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :DeviceFailure
                :DevicePerformance
                :DeviceSafety
                :DiagnosticError
                :PatientHarm
                :ProductQuality
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :High
                :Low
                :Medium
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :InSituCorrection
                :Recall
                :SafetyAlert
                :UserNotice
              )
] .


#################################################################
#    Rules
#################################################################

<urn:swrl:var#a> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

