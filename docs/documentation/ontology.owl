    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassC">
        <rdfs:comment xml:lang="en">Moderate to high individual risk and low to moderate public health risk (IVDR).</rdfs:comment>
        <rdfs:label xml:lang="en">Class C</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassD">
        <rdfs:comment xml:lang="en">High individual risk and high public health risk (IVDR).</rdfs:comment>
        <rdfs:label xml:lang="en">Class D</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassIII">
        <rdfs:comment xml:lang="en">Highest risk class for medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassIIa">
        <rdfs:comment xml:lang="en">Low to moderate risk class for medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIa</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ClassIIb">
        <rdfs:comment xml:lang="en">Moderate to high risk class for medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIb</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Closed">
        <rdfs:comment xml:lang="en">Status indicating that the action has been completed.</rdfs:comment>
        <rdfs:label xml:lang="en">Closed</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Critical">
        <rdfs:comment xml:lang="en">Highest level of severity representing extreme danger to life.</rdfs:comment>
        <rdfs:label xml:lang="en">Critical</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DeviceFailure">
        <rdfs:comment xml:lang="en">Risk category involving the breakdown or failure of the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Failure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DevicePerformance">
        <rdfs:comment xml:lang="en">Risk category involving inadequate performance of the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Performance</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DeviceSafety">
        <rdfs:comment xml:lang="en">Risk category involving compromised safety of the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Safety</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DiagnosticError">
        <rdfs:comment xml:lang="en">Risk category involving incorrect diagnostic results.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Error</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#High">
        <rdfs:comment xml:lang="en">High likelihood of occurrence.</rdfs:comment>
        <rdfs:label xml:lang="en">High</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#IVDR">
        <rdfs:comment xml:lang="en">In Vitro Diagnostic Regulation (EU) 2017/746.</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Low">
        <rdfs:comment xml:lang="en">Low likelihood of occurrence.</rdfs:comment>
        <rdfs:label xml:lang="en">Low</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#MDR">
        <rdfs:comment xml:lang="en">Medical Device Regulation (EU) 2017/745.</rdfs:comment>
        <rdfs:label xml:lang="en">MDR</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Medium">
        <rdfs:comment xml:lang="en">Medium likelihood of occurrence.</rdfs:comment>
        <rdfs:label xml:lang="en">Medium</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Moderate">
        <rdfs:comment xml:lang="en">Moderate level of severity.</rdfs:comment>
        <rdfs:label xml:lang="en">Moderate</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Open">
        <rdfs:comment xml:lang="en">Status indicating that the action is still in progress.</rdfs:comment>
        <rdfs:label xml:lang="en">Open</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#PatientHarm">
        <rdfs:comment xml:lang="en">Risk category involving direct injury to the patient.</rdfs:comment>
        <rdfs:label xml:lang="en">Patient Harm</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ProductQuality">
        <rdfs:comment xml:lang="en">Risk category related to manufacturing or product defects.</rdfs:comment>
        <rdfs:label xml:lang="en">Product Quality</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Serious">
        <rdfs:comment xml:lang="en">High level of severity involving significant injury or impairment.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious</rdfs:label>
    </rdf:Description>
    


