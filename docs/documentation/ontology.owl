    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#dcterms_identifier"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasActionType -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasActionType">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#CorrectiveAction"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#ActionType"/>
        <rdfs:comment xml:lang="en">Links a corrective action to its specific typology.</rdfs:comment>
        <rdfs:label xml:lang="en">has action type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasCategory -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasCategory">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Risk"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#RiskCategory"/>
        <rdfs:comment xml:lang="en">Associates a risk with its broad category.</rdfs:comment>
        <rdfs:label xml:lang="en">has category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasCorrectiveAction">
        <owl:inverseOf rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isCorrectiveActionOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Links an incident to the corrective action taken to address it.</rdfs:comment>
        <rdfs:label xml:lang="en">has corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasDevice -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasDevice">
        <owl:inverseOf rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isDeviceInvolvedIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Device"/>
        <rdfs:comment xml:lang="en">Relates an incident to the specific medical device involved.</rdfs:comment>
        <rdfs:label xml:lang="en">has device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasDeviceType -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasDeviceType">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Device"/>
                    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident"/>
                    <rdf:Description rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Risk"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#DeviceType"/>
        <rdfs:comment xml:lang="en">Classifies a device, incident, or risk into a specific device functional type.</rdfs:comment>
        <rdfs:label xml:lang="en">has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasIncidentType -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasIncidentType">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#IncidentType"/>
        <rdfs:comment xml:lang="en">Classifies an incident into a specific type based on severity.</rdfs:comment>
        <rdfs:label xml:lang="en">has incident type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasManufacturer -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasManufacturer">
        <owl:inverseOf rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isManufacturerOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Device"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links a device to its legal manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasProbability -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasProbability">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Risk"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Probability"/>
        <rdfs:comment xml:lang="en">Indicates the likelihood of a specific risk occurring.</rdfs:comment>
        <rdfs:label xml:lang="en">has probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRegulatoryFramework -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRegulatoryFramework">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Device"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Links a device to the regulations governing its use.</rdfs:comment>
        <rdfs:label xml:lang="en">has regulatory framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasReportedByEntity -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasReportedByEntity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Manufacturer"/>
        <rdfs:comment xml:lang="en">Identifies the manufacturer reporting the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">has reported by entity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRisk -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRisk">
        <owl:inverseOf rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isRiskOfIncident"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Risk"/>
        <rdfs:comment xml:lang="en">Associates an incident with the specific risk it represents.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRiskClass -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRiskClass">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Device"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#RiskClass"/>
        <rdfs:comment xml:lang="en">Indicates the risk classification of a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRiskType -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasRiskType">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Risk"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#RiskType"/>
        <rdfs:comment xml:lang="en">Specifies the specific nature of the danger represented by a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasSeverity -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasSeverity">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Risk"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Severity"/>
        <rdfs:comment xml:lang="en">Indicates the potential severity of a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">has severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasStatus -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#hasStatus">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#CorrectiveAction"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Status"/>
        <rdfs:comment xml:lang="en">Defines the current state of a corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isCorrectiveActionOf -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isCorrectiveActionOf">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#CorrectiveAction"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident"/>
        <rdfs:comment xml:lang="en">Indicates the incident for which a specific corrective action was implemented.</rdfs:comment>
        <rdfs:label xml:lang="en">is corrective action of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isDeviceInvolvedIn -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isDeviceInvolvedIn">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Device"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident"/>
        <rdfs:comment xml:lang="en">Links a medical device to an incident in which it was involved.</rdfs:comment>
        <rdfs:label xml:lang="en">is device involved in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isManufacturerOf -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isManufacturerOf">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Manufacturer"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Device"/>
        <rdfs:comment xml:lang="en">Identifies the medical devices produced by a specific manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">is manufacturer of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isRiskOfIncident -->


    <owl:ObjectProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#isRiskOfIncident">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Risk"/>
        <rdfs:range rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Incident"/>
        <rdfs:comment xml:lang="en">Associates a specific risk with the incident that materialized it.</rdfs:comment>
        <rdfs:label xml:lang="en">is risk of incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#action_date -->


    <owl:DatatypeProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#action_date">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://purl.org/dc/terms/date"/>
        <rdfs:comment xml:lang="en">The date when the corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#authorization_number -->


    <owl:DatatypeProperty rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#authorization_number">
        <rdfs:domain rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The official authorization or certification number of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


