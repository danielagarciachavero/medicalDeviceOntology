    <!-- http://purl.org/dc/terms/date -->


    <rdfs:Datatype rdf:about="http://purl.org/dc/terms/date"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <rdfs:Datatype rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/identifier -->


    <rdfs:Datatype rdf:about="http://purl.org/dc/terms/identifier"/>
    


