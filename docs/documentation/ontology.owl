<?xml version="1.0"?>
<rdf:RDF xmlns="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#"
     xml:base="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:bibo="http://purl.org/ontology/bibo/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="https://schema.org/"
     xmlns:MDRS-Onto="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#">
    <owl:Ontology rdf:about="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl">
        <owl:versionIRI rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto-1.0.0.owl"/>
        <dc:contributor xml:lang="en">UOC - Universitat Oberta de Catalunya</dc:contributor>
        <dc:creator xml:lang="en">Daniela Garcia Chavero</dc:creator>
        <dc:creator xml:lang="en">Johan Marin Chamorro</dc:creator>
        <dc:description xml:lang="en">The medical device ontology is designed to structure and represent information about medical devices and post-market surveillance within the European regulatory framework (MDR/IVDR).</dc:description>
        <dc:title xml:lang="en">Medical Device Regulatory and Surveillance Ontology</dc:title>
        <terms:abstract xml:lang="en">Ontology detailing medical devices, post-market surveillance, incidents, and field safety corrective actions compliant with EU MDR/IVDR regulations.</terms:abstract>
        <terms:bibliographicCitation xml:lang="en">Garcia Chavero, D. and Marin Chamorro, J. Medical Device Regulatory and Surveillance Ontology. 2026.</terms:bibliographicCitation>
        <terms:created xml:lang="en">2026-04-23</terms:created>
        <terms:issued xml:lang="en">2026-04-23</terms:issued>
        <terms:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified xml:lang="en">2026-04-23</terms:modified>
        <terms:publisher xml:lang="en">FUOC - Fundació Universitat Oberta de Catalunya</terms:publisher>
        <terms:source rdf:resource="https://eur-lex.europa.eu/eli/reg/2017/745/oj"/>
        <bibo:doi xml:lang="en">10.5281/zenodo.1000000</bibo:doi>
        <bibo:status xml:lang="en">Published</bibo:status>
        <vann:preferredNamespacePrefix xml:lang="en">mdo</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="https://danielagarciachavero.github.io/medicalDeviceOntology/MDRS-Onto.owl#"/>
        <owl:versionInfo xml:lang="en">Final Version - PEC2</owl:versionInfo>
        <schema:citation xml:lang="en">Garcia Chavero, D. and Marin Chamorro, J. Medical Device Regulatory and Surveillance Ontology.</schema:citation>
        <schema:includedInDataCatalog rdf:resource="https://lov.linkeddata.es/dataset/lov"/>
        <schema:logo rdf:resource="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8a/Small_logo_UOC.svg/3840px-Small_logo_UOC.svg.png"/>
        <mod:createdWith rdf:resource="https://chowlk.linkeddata.es/"/>
    </owl:Ontology>
    


